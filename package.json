{
  "name": "sol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:frontend": "cd frontend && npx vite",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit && cd frontend && npx tsc --noEmit",
    "build:frontend": "cd frontend && npx vite build",
    "build:all": "npm run build && npm run build:frontend",
    "lint": "tsc --noEmit && cd frontend && npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
